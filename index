<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Полное восстановление портфеля облигаций — Июнь 2026</title>
    <style>
        :root {
            --bg: #0a0e13;
            --card: #11171f;
            --border: #1e2a36;
            --text: #d1d7e0;
            --muted: #7a8494;
            --green: #2ea955;
            --red: #e0556a;
            --yellow: #d4a43a;
            --blue: #5b9cf5;
            --accent-ofz: #2973d6;
            --accent-fund: #7c4dff;
            --accent-corp: #e67e3a;
            --accent-new: #00c9a7;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            background: var(--bg);
            color: var(--text);
            font-family: 'Inter', 'Segoe UI', system-ui, sans-serif;
            line-height: 1.5;
            padding: 16px;
        }
        .container { max-width: 1400px; margin: 0 auto; }

        /* Header */
        .header {
            text-align: center;
            padding: 24px 16px 20px;
            border-bottom: 1px solid var(--border);
            margin-bottom: 24px;
        }
        .header .icon { font-size: 48px; margin-bottom: 8px; }
        .header h1 {
            font-size: 1.8em;
            font-weight: 800;
            background: linear-gradient(135deg, #5b9cf5, #a78bfa);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .header .subtitle { color: var(--muted); font-size: 0.95em; }
        .header .badge-row {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 10px;
            margin-top: 12px;
        }
        .badge {
            padding: 6px 16px;
            border-radius: 20px;
            font-size: 0.82em;
            font-weight: 700;
            border: 1px solid var(--border);
            background: #1a2433;
        }
        .badge.ofz { color: #5b9cf5; border-color: #2973d666; }
        .badge.corp { color: #e67e3a; border-color: #e67e3a66; }
        .badge.fund { color: #7c4dff; border-color: #7c4dff66; }
        .badge.new { color: #00c9a7; border-color: #00c9a766; }
        .badge.count { color: var(--text); }

        /* Stats */
        .stats {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 10px;
            margin-bottom: 24px;
        }
        .stat {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 16px;
            text-align: center;
        }
        .stat .val { font-size: 1.6em; font-weight: 800; }
        .stat .lbl { font-size: 0.78em; color: var(--muted); margin-top: 2px; }
        .stat.g .val { color: var(--green); }
        .stat.b .val { color: var(--blue); }
        .stat.y .val { color: var(--yellow); }
        .stat.r .val { color: var(--red); }
        .stat.n .val { color: var(--accent-new); }

        /* Section */
        .section {
            margin: 28px 0 16px;
            padding-bottom: 8px;
            border-bottom: 2px solid var(--border);
        }
        .section h2 {
            font-size: 1.2em;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .section .count { font-size: 0.7em; color: var(--muted); font-weight: 400; }

        /* Table */
        .table-wrap {
            overflow-x: auto;
            margin: 12px 0 20px;
            border-radius: 12px;
            border: 1px solid var(--border);
        }
        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.85em;
            min-width: 900px;
        }
        thead th {
            background: #151d29;
            padding: 12px 10px;
            text-align: left;
            font-weight: 700;
            font-size: 0.78em;
            text-transform: uppercase;
            letter-spacing: 0.4px;
            color: var(--muted);
            border-bottom: 2px solid var(--border);
            white-space: nowrap;
        }
        tbody td {
            padding: 10px;
            border-bottom: 1px solid #1a2533;
            vertical-align: middle;
        }
        tbody tr {
            transition: background 0.15s;
        }
        tbody tr:hover { background: #161f2c; }
        tbody tr.new-addition {
            background: #0a2a23;
            border-left: 3px solid var(--accent-new);
        }
        tbody tr.new-addition:hover { background: #0d332b; }
        .isin-code {
            font-family: 'SF Mono', 'Fira Code', monospace;
            font-size: 0.8em;
            color: var(--blue);
            cursor: pointer;
            user-select: all;
            white-space: nowrap;
        }
        .isin-code:hover { text-decoration: underline; }
        .qty { font-weight: 700; text-align: center; font-size: 1em; }
        .price { text-align: right; font-family: monospace; }
        .total { text-align: right; font-family: monospace; font-weight: 600; }
        .muted { color: var(--muted); font-size: 0.82em; }
        .tag-sm {
            display: inline-block;
            font-size: 0.7em;
            padding: 2px 8px;
            border-radius: 8px;
            font-weight: 700;
            white-space: nowrap;
        }
        .tag-ofz { background: #1a3060; color: #5b9cf5; }
        .tag-corp { background: #3d2518; color: #e67e3a; }
        .tag-fund { background: #281d4a; color: #7c4dff; }
        .tag-new { background: #0a332b; color: #00c9a7; }

        /* Checkbox */
        .chk input { display: none; }
        .chk label {
            display: flex;
            align-items: center;
            gap: 6px;
            cursor: pointer;
            font-size: 0.75em;
            color: var(--muted);
            white-space: nowrap;
        }
        .chk .box {
            width: 20px;
            height: 20px;
            border: 2px solid #334155;
            border-radius: 4px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }
        .chk input:checked + .box {
            background: var(--green);
            border-color: var(--green);
        }
        .chk input:checked + .box::after { content: '✓'; color: #fff; font-weight: 700; }
        .chk input:checked ~ span { color: var(--green); }

        /* Progress */
        .progress-card {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 14px;
            padding: 20px 24px;
            margin: 24px 0;
        }
        .progress-card h3 { font-size: 1em; margin-bottom: 12px; }
        .bar-outer {
            height: 18px;
            background: #0d141e;
            border-radius: 10px;
            border: 1px solid var(--border);
            overflow: hidden;
        }
        .bar-inner {
            height: 100%;
            background: linear-gradient(90deg, #2973d6, #2ea955);
            border-radius: 10px;
            width: 0%;
            transition: width 0.4s;
        }
        .progress-card .txt { text-align: center; margin-top: 8px; font-size: 0.85em; color: var(--muted); }

        /* Summary */
        .summary {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(100px, 1fr));
            gap: 8px;
            margin-top: 16px;
            text-align: center;
            font-size: 0.82em;
        }
        .summary div { padding: 8px; background: #0d141e; border-radius: 8px; }
        .summary .big { font-size: 1.3em; font-weight: 700; }

        .footer {
            margin-top: 40px;
            padding: 20px;
            text-align: center;
            color: var(--muted);
            font-size: 0.8em;
            border-top: 1px solid var(--border);
        }
        .copy-toast {
            position: fixed;
            top: 16px;
            left: 50%;
            transform: translateX(-50%);
            background: var(--green);
            color: #fff;
            padding: 10px 24px;
            border-radius: 20px;
            font-weight: 700;
            font-size: 0.9em;
            z-index: 999;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s;
        }
        .copy-toast.show { opacity: 1; }

        @media (max-width: 768px) {
            .header h1 { font-size: 1.3em; }
            table { font-size: 0.72em; }
        }
    </style>
</head>
